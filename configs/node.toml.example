# Node Server runtime config.

[server]
# Listen address for the local Node HTTP API.
# Main may need to reach this address/port unless all traffic is tunneled over WS.
host = "0.0.0.0"
# Node HTTP API port. Health check is exposed at /health on this port.
port = 4456

[database]
# SQLite file used by the Node for local auth/session metadata.
# Relative paths are resolved from the repo root.
path = "database/auth.db"

[node]
# Choose one of the two connection modes below.
# 1) Direct WS mode: set main_server_url and leave main_register_url empty.
# 2) HTTP registration mode: set main_register_url and leave main_server_url empty.

# Shared identity / metadata fields.
# Leave id and name empty to auto-derive from the local hostname if you do not care.
id = ""
name = ""
register_token = ""
labels = []
capabilities = ["claude", "codex"]

# Mode 1: Direct Node -> Main WebSocket.
# Example:
# main_server_url = "ws://127.0.0.1:4457/ws/node"
main_server_url = ""

# Mode 2: HTTP registration + Main callback.
# Example:
# main_register_url = "http://127.0.0.1:4457/api/nodes/register"
main_register_url = ""

# Optional callback address override used by HTTP registration mode.
# Set these when Main must connect back to a different host/port than the
# node process sees locally.
advertise_host = ""
advertise_port = 0

[auth]
# Optional node-local auth settings.
# In normal Main+Node deployments you can omit these and use defaults.
platform_mode = false
jwt_secret = ""

[filesystem]
# Optional file tree limits for very large workspaces.
file_tree_max_nodes = 2500
file_tree_max_depth = 6

[terminal]
# Set to false to disable terminal access entirely for this node.
# When disabled, the shell tab is shown as unavailable and backend shell
# requests are rejected even if the browser tries to open them.
enabled = true
# Optional shell override for the built-in terminal.
default_shell = "/bin/bash"

[providers.claude]
# Optional Claude tuning.
tool_approval_timeout_ms = 55000
context_window = 160000

[providers.codex]
# Optional Codex tuning.
tool_approval_timeout_ms = 55000
